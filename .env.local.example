# =============================================================================
# Алфавит — шаблон переменных окружения (скопируй в .env.local, секреты не коммить)

# ─── База данных (Neon PostgreSQL v17) ───────────────────────────────────────
# Pooled — используется приложением в runtime (lib/db.ts → Prisma Client)
# Source: Neon Console > Connection Details > Pooled connection (hostname includes -pooler)
DATABASE_URL="postgresql://[user]:[password]@[host]-pooler.[region].aws.neon.tech/[database]?sslmode=require"

# Direct — используется Prisma CLI для миграций (prisma.config.ts)
# Source: Neon Console > Connection Details > Direct connection (без -pooler)
DIRECT_URL="postgresql://[user]:[password]@[host].[region].aws.neon.tech/[database]?sslmode=require"

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET="[generate-with: openssl rand -base64 32]"

# URL приложения (Auth.js callback)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin credentials (seed) ────────────────────────────────────────────────
# Используется только для prisma seed (prisma/seed.ts)
ADMIN_EMAIL="admin@alphabet.local"
ADMIN_PASSWORD="change-me-in-production"

# ─── Google OAuth (post-MVP) ─────────────────────────────────────────────────
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ─── AI / OpenRouter ─────────────────────────────────────────────────────────
# Ключ от OpenRouter API (https://openrouter.ai → Keys)
NEXT_PUBLIC_OPENROUTER_API_KEY="[your-openrouter-api-key]"

# ─── Dev flags ───────────────────────────────────────────────────────────────
# NODE_ENV=development
